# Web3Forms — get a free access key at https://web3forms.com
# Sign up with info@quantixit.uk and paste the key below.
# In Vercel: Settings → Environment Variables → add NEXT_PUBLIC_WEB3FORMS_KEY
NEXT_PUBLIC_WEB3FORMS_KEY=your-web3forms-access-key-here

# Public site URL (used for SEO canonical URLs, sitemap, OG tags)
NEXT_PUBLIC_SITE_URL=https://quantixit.uk
